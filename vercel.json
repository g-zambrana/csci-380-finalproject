{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/",
      "destination": "/login",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/login",
      "destination": "/pages/login"
    },
    {
      "source":"/mood-tracker",
      "destination":"/pages/mood-tracker"
    },
    {
      "source": "/register",
      "destination": "/pages/register"
    },
    {
      "source": "/home",
      "destination": "/pages/home"
    },
    {
      "source": "/reset-password",
      "destination": "/pages/reset-password"
    },
    {
      "source": "/update-password",
      "destination": "/pages/update-password"
    }
  ]
}