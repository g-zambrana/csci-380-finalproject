<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>MindBloom - Previous Entries</title>

<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Segoe UI', sans-serif;
}

body {
    background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
    min-height: 100vh;
    padding: 30px;
}

/* Logo */
.logo {
    text-align: center;
    font-size: 60px;
    font-weight: 700;
    color: #6b8f71;
    margin-bottom: 20px;
    animation: fadeIn 0.8s ease;
}

/* Container */
.container {
    max-width: 700px;
    margin: auto;
}

/* Header */
.header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
}

h2 {
    color: #333;
}

/* Back Button */
.back-btn {
    padding: 8px 15px;
    border-radius: 20px;
    border: none;
    background: #6b8f71;
    color: white;
    cursor: pointer;
    transition: 0.3s;
}

.back-btn:hover {
    background: #5a7c60;
}

/* Entry Cards */
.entry {
    background: white;
    padding: 20px;
    border-radius: 15px;
    margin-bottom: 15px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.1);
}

.date {
    font-size: 12px;
    color: #888;
    margin-bottom: 10px;
}

.text {
    color: #333;
    line-height: 1.5;
}

/* Empty state */
.empty {
    text-align: center;
    color: #666;
    margin-top: 50px;
}

/* Animations */
@keyframes fadeIn {
    from {opacity: 0;}
    to {opacity: 1;}
}

@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}
</style>
</head>

<body>

<div class="logo">MindBloom</div>

<div class="container">

    <div class="header">
        <h2>Your Previous Entries</h2>
        <button class="back-btn" onclick="goBack()">Back</button>
    </div>

    <div id="entriesContainer"></div>

</div>

<script>
function goBack() {
    window.history.back(); // goes back to reflection page
}

function loadEntries() {
    const container = document.getElementById("entriesContainer");
    let entries = JSON.parse(localStorage.getItem("reflections")) || [];

    if (entries.length === 0) {
        container.innerHTML = '<div class="empty">No entries yet.</div>';
        return;
    }

    // newest first
    entries.reverse();

    entries.forEach(entry => {

        div.innerHTML = `
            <div class="date">${entry.date}</div>
            <div class="text">${entry.text}</div>
        `;

        container.appendChild(div);
    });
}

loadEntries();
</script>

</body>
</html>
